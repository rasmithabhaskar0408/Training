# odd & even
list=[10,501,22,37,100,999,87,351] #given list
even=[] # declaring empty list
odd=[] # declairing empty list
for n in list:
  if  n%2 == 0 :
    even.append(n) #added even number in even list usin append
  
  else :
    odd.append(n) #added odd number in odd list
 

print("even:",even) #printing out side the loop 
print("odd:",odd)


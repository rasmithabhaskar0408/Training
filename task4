# non repetive integers
nums = [2, 3, 4, 2, 3, 5, 6, 4]

# Step 1: count frequency
count = {}

for n in nums:
    if n in count:
        count[n] += 1
    else:
        count[n] = 1

# Step 2: find first non-repeating
for n in nums:
    if count[n] == 1:
        print("First non-repeating element:", n)
        break

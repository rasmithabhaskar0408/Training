for i1 in range(0,11):   # 10 coins for 1rs
    for i2 in range(0,6):   # 5 coins for 2rs
        for i3 in range(0,3):   # 2 coins for 5rs
            for i4 in range(0,2):   # 1 coin for 10rs
                
                total = i1*1 + i2*2 + i3*5 + i4*10

                if total == amount:
                    print("1rs:", i1, "2rs:", i2, "5rs:", i3, "10rs:", i4)

